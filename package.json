{
    "name": "@ulb-darmstadt/shacl-form",
    "version": "3.2.1",
    "description": "SHACL form generator",
    "main": "dist/index.js",
    "module": "dist/index.js",
    "types": "dist/form.d.ts",
    "typesVersions": {
        "*": {
            "sparql": [
                "dist/query/sparql.d.ts"
            ],
            "plugins/*": [
                "dist/plugins/*"
            ]
        }
    },
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/form.d.ts",
            "import": "./dist/index.js"
        },
        "./sparql": {
            "types": "./dist/query/sparql.d.ts",
            "import": "./dist/sparql.js"
        },
        "./plugins/*": "./dist/plugins/*"
    },
    "files": [
        "dist",
        "src/query/query-mode.md"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ULB-Darmstadt/shacl-form.git"
    },
    "author": "ULB Darmstadt",
    "license": "MIT",
    "homepage": "https://ulb-darmstadt.github.io/shacl-form/",
    "keywords": [
        "SHACL",
        "form",
        "generator",
        "RDF",
        "metadata",
        "editor",
        "viewer"
    ],
    "scripts": {
        "dev": "vite serve ./demo --host",
        "build": "npm run clean && tsc && npm run build-lib && npm run build-sparql && npm run build-bundle && npm run build-plugins",
        "preview": "vite preview",
        "test": "web-test-runner --config test/config.js",
        "lint": "eslint \"src/**/*.{ts,tsx}\"",
        "clean": "rimraf dist",
        "build-lib": "vite build  -c ./vite.config.ts",
        "build-sparql": "vite build -c ./vite.config.sparql.ts",
        "build-bundle": "vite build  -c ./vite.config.bundle.ts",
        "build-plugins": "vite build -c ./vite.config.plugins.ts"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@open-wc/testing": "^5.0.0",
        "@remcovaes/web-test-runner-vite-plugin": "^1.4.1",
        "@types/jsonld": "^1.5.15",
        "@types/leaflet": "^1.9.21",
        "@types/leaflet-editable": "^1.2.7",
        "@types/leaflet.heat": "^0.2.5",
        "@types/mapbox__mapbox-gl-draw": "^1.4.9",
        "@types/mocha": "^10.0.10",
        "@types/n3": "^1.26.1",
        "@typescript-eslint/eslint-plugin": "^8.64.0",
        "@typescript-eslint/parser": "^8.64.0",
        "@web/test-runner": "^1.0.0",
        "@web/test-runner-chrome": "^1.0.0",
        "@web/test-runner-puppeteer": "^1.0.0",
        "eslint": "^10.7.0",
        "globals": "^17.7.0",
        "puppeteer": "^25.3.0",
        "rdf-isomorphic": "^2.0.1",
        "rimraf": "^6.1.3",
        "rollup-plugin-peer-deps-external": "^2.2.4",
        "typescript": "^6.0.3",
        "vite": "^8.1.5"
    },
    "peerDependencies": {
        "@ro-kit/ui-widgets": "^1.0.50",
        "jsonld": "^9.0.0",
        "leaflet": "^1.9.4",
        "leaflet-editable": "^1.3.2",
        "leaflet.fullscreen": "^5.3.3",
        "leaflet.heat": "^0.2.0",
        "n3": "^1.0.26 || ^2.0.0",
        "rdfxml-streaming-parser": "^3.1.0",
        "shacl-engine": "^1.1.2",
        "uuid": "^13.0.0"
    },
    "allowScripts": {
        "puppeteer@24.43.1": true,
        "puppeteer@25.3.0": true
    }
}
